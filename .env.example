# Replicate API (geração FLUX/Kling) — copie para .env
REPLICATE_API_TOKEN=

# Base URL pública dos assets NV5
NEXT_PUBLIC_ASSET_BASE=/assets/nv11

# Motion / performance — S02 usa frames WebP (sem vídeo)
NEXT_PUBLIC_ENABLE_F2F=true
NEXT_PUBLIC_ENABLE_VIDEO=false
NEXT_PUBLIC_MOBILE_BREAKPOINT=900

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
