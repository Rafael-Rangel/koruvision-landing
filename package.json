{
  "name": "flowia-landing",
  "version": "1.0.0",
  "private": true,
  "browserslist": [
    "chrome >= 92",
    "firefox >= 90",
    "safari >= 15",
    "edge >= 92"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "generate:assets": "python scripts/nv5_pipeline.py --all",
    "generate:priority": "python scripts/nv5_pipeline.py --priority",
    "generate:status": "python scripts/nv5_pipeline.py --status",
    "generate:asset-map": "python scripts/build_asset_map_master.py",
    "generate:nv11": "python scripts/nv11_pipeline.py",
    "generate:nv11:priority": "python scripts/nv11_pipeline.py --priority",
    "generate:nv11:bootstrap": "python scripts/nv11_bootstrap.py",
    "generate:nv11:f2f": "python scripts/nv11_pipeline.py --f2f-only",
    "f2f:owl": "python scripts/nv11_pipeline.py --f2f-only --force --lite --seq NV11-F2F-001"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "lenis": "^1.3.24",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "typescript": "^5.7.2"
  }
}
